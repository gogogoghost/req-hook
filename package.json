  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "dist/req-hook.cjs.js",
  "module": "dist/req-hook.es.js",
  "types": "dist/index.d.ts",
  "repository": "git@github.com:gogogoghost/req-hook.git",
  "homepage": "https://github.com/gogogoghost/req-hook",
